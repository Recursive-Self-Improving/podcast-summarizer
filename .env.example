# Copy this file to .env for local development, or export these variables in your shell.
# Shell environment variables take precedence over values in .env.
# Runtime dependencies: Go, Python 3, pip, yt-dlp, ffmpeg, and faster-whisper.
# When deploying with Docker (see Dockerfile and docker-compose.yml), yt-dlp, ffmpeg,
# python3, faster-whisper, and nodejs are baked into the image. The compose file sets
# SQLITE_PATH=/data/bot.db and TEMP_ROOT=/tmp/podcast via named volumes, so leave
# those unset in .env to use the container defaults.
# Install faster-whisper with: pip install faster-whisper

# Required Telegram settings
TELEGRAM_BOT_TOKEN=
BOT_OWNER_ID=

# Required OpenAI-compatible API settings
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional OpenAI-compatible API settings
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional storage settings
SQLITE_PATH=./data/bot.db
# Optional temp root for subtitles, audio, and document fallbacks. Empty uses Go's system temp dir (TMPDIR or /tmp).
TEMP_ROOT=

# Optional external binary paths and yt-dlp settings
# If running under systemd or another restricted user, set absolute paths when PATH does not include these binaries.
YT_DLP_PATH=yt-dlp
# Extra args are passed to subtitle and audio yt-dlp calls before app-managed options.
# For current YouTube JS challenges, install nodejs or deno and use the mandatory JS runtime + EJS solver flags.
# Example: YT_DLP_ARGS=--extractor-args youtube:player_client=android_vr --js-runtimes node --remote-components ejs:github
YT_DLP_ARGS=--extractor-args youtube:player_client=android_vr --js-runtimes node --remote-components ejs:github
FFMPEG_PATH=ffmpeg
PYTHON_PATH=python3

# Optional faster-whisper settings
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_SEGMENT_SECONDS=300

# Optional Telegram settings
TELEGRAM_SKIP_OLD_UPDATES=true
# Optional: mirror newly generated successful summaries to a Telegram channel after user/watch delivery succeeds.
# Use the numeric channel ID (usually starts with -100), not @username. Leave empty to disable.
SUMMARY_BROADCAST_CHANNEL_ID=
